# Contract Agent deployment overlay template.
# Primary file-based runtime configuration lives in .run/config.yaml.
# CLI model profiles are stored in .run/cli_profile.yaml.

# Preferred model configuration keys.
LLM_PROVIDER=openai_compatible
LLM_API_KEY=
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_CHAT_MODEL=qwen-max
LLM_EMBEDDING_MODEL=text-embedding-v4
LLM_TEMPERATURE=0
LLM_USE_RESPONSES_API=true
EMBEDDING_BATCH_SIZE=10

# Role-specific overrides. Leave blank to inherit the LLM_* values in code.
CHAT_PROVIDER=
CHAT_API_KEY=
CHAT_BASE_URL=
CHAT_MODEL=
EMBEDDING_PROVIDER=
EMBEDDING_API_KEY=
EMBEDDING_BASE_URL=
EMBEDDING_MODEL=

# Rerank configuration.
RERANK_PROVIDER=qwen
RERANK_API_KEY=
RERANK_BASE_URL=
RERANK_MODEL=qwen3-rerank
RERANK_ENDPOINT=
RERANK_TIMEOUT_SECONDS=8
RERANK_MAX_RETRIES=0

# Retrieval and vector store configuration.
VECTOR_BACKEND=faiss
KNOWLEDGE_VECTOR_STORE_DIR=knowledge/ingested/laws_faiss
MILVUS_URI=http://127.0.0.1:19530
MILVUS_COLLECTION_NAME=legal_knowledge_chunks
MILVUS_CONSISTENCY_LEVEL=Session
RETRIEVAL_ENABLE_RERANK=true
RETRIEVAL_ENABLE_HYBRID=true
RETRIEVAL_FETCH_K=12
RETRIEVAL_FINAL_K=4
RETRIEVAL_DENSE_POOL_K=36

# Runtime services.
POSTGRES_DSN=postgresql+psycopg://postgres:postgres@127.0.0.1:5432/contract_agent
REACT_MAX_STEPS=3
MAX_UPLOAD_SIZE_BYTES=5242880
MAX_REDRAFT_CHUNK_CHARS=12000
STREAM_MAX_SECONDS=24.0
STREAM_MAX_CHARS=900
AGENT_GRPC_PORT=50051

# Parser configuration.
PARSER_DEFAULT_CONVERTER=docling
PARSER_ENABLED_CONVERTERS=docling
PARSER_FALLBACK_ORDER=docling
PARSER_ALLOW_CONVERTER_FALLBACK=true
PARSER_STRICT_CONVERTER_AVAILABILITY=false
PARSER_ALLOWED_SUFFIXES=.txt,.docx,.pdf
PARSER_ALLOW_PATH_INPUT=true
# Reserved until URL source loading is implemented; true fails fast today.
PARSER_ALLOW_URL_INPUT=false
PARSER_TRUSTED_PATH_ROOTS=
PARSER_MAX_INPUT_BYTES=
PARSER_PRESERVE_RAW_TEXT=true

# Parser detectors and chunking.
PARSER_ENABLED_DETECTORS=metadata,clause_header,definition,reference
PARSER_DETECTOR_PROFILE=builtin_zh_contract_v1
PARSER_DETECTOR_RULES_PATH=
PARSER_MIN_DETECTOR_CONFIDENCE=0.60
PARSER_STORE_DETECTOR_REASONS=true
PARSER_CHUNK_MAX_CHARS=1200
PARSER_CHUNK_TARGET_CHARS=500
PARSER_MIN_HEADER_CONFIDENCE=0.65

# Optional parser converters. Disabled by default and loaded lazily.
PARSER_MARKITDOWN_ENABLED=false
PARSER_DOCLING_ENABLED=true
PARSER_DOCLING_ENABLE_OCR=true
PARSER_DOCLING_OCR_LANG=chinese
PARSER_DOCLING_FORCE_FULL_PAGE_OCR=true
PARSER_DOCLING_BITMAP_AREA_THRESHOLD=0.02
PARSER_DOCLING_TEXT_SCORE=0.35
PARSER_DOCLING_DO_TABLE_STRUCTURE=true
PARSER_DOCLING_COMPACT_TABLES=true
PARSER_DOCLING_ENABLE_REMOTE_SERVICES=false

# Backward-compatible aliases still accepted by runtime/config.py:
# QWEN_API_KEY, QWEN_BASE_URL, QWEN_CHAT_MODEL, QWEN_EMBEDDING_MODEL,
# OPENAI_API_KEY, OPENAI_BASE_URL, OPENAI_CHAT_MODEL, OPENAI_EMBEDDING_MODEL
